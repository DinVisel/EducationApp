# Example environment file for the backend Docker stack.
# Copy to `.env` (same folder as the compose file) and fill in real values.
# `.env` is git-ignored — never commit real secrets.
#
#   - On your server: place next to docker-compose.prod.yml at /var/www/eduapp/.env
#   - Locally (root docker-compose.yml): only JWT_KEY, POSTGRES_PASSWORD and
#     ADMIN_ORIGIN are needed; IMAGE is ignored because it builds from source.

# --- Image (server / prod only) ---------------------------------------------
# The image pushed by CI. Replace <your-dockerhub-username>.
IMAGE=docker.io/<your-dockerhub-username>/teacher-tracker-api:latest

# --- Database ---------------------------------------------------------------
# Username/DB name have sensible defaults; you only must set a strong password.
POSTGRES_USER=postgres
POSTGRES_DB=TeacherTrackerDb
POSTGRES_PASSWORD=change-me-to-a-strong-password

# --- Auth (JWT) -------------------------------------------------------------
# MUST be a long random secret (>= 32 chars). Generate one, e.g.:
#   openssl rand -base64 48
JWT_KEY=change-me-to-a-long-random-secret-at-least-32-chars
JWT_ISSUER=TeacherTracker.Api
JWT_AUDIENCE=TeacherTracker.App

# --- CORS -------------------------------------------------------------------
# Exact origin of the admin dashboard (scheme + host, no trailing slash).
# Local dev: http://localhost:3000   Prod: https://<your-vercel-domain>
ADMIN_ORIGIN=http://localhost:3000
