@host = http://localhost:5001

### Health check
GET {{host}}/

### Register (returns { token, teacher })
# @name register
POST {{host}}/api/auth/register
Content-Type: application/json

{
  "firstName": "Arda",
  "lastName": "Ozcan",
  "email": "arda@example.com",
  "password": "secret123"
}

### Login (returns { token, teacher })
# @name login
POST {{host}}/api/auth/login
Content-Type: application/json

{
  "email": "arda@example.com",
  "password": "secret123"
}

### Capture the token from the login response for the calls below
@token = {{login.response.body.token}}

### Current profile
GET {{host}}/api/auth/me
Authorization: Bearer {{token}}

### Update profile
PUT {{host}}/api/auth/me
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "firstName": "Arda",
  "lastName": "Özcan",
  "email": "arda@example.com"
}

### Create a student (teacherId comes from the token)
POST {{host}}/api/students
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "firstName": "Zeynep",
  "lastName": "Kaya",
  "studentNumber": "3B-07"
}

### List my students
GET {{host}}/api/students
Authorization: Bearer {{token}}

### Get one student
GET {{host}}/api/students/1
Authorization: Bearer {{token}}

### Update a student
PUT {{host}}/api/students/1
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "firstName": "Zeynep",
  "lastName": "Kaya",
  "studentNumber": "3B-08"
}

### Delete a student
DELETE {{host}}/api/students/1
Authorization: Bearer {{token}}
