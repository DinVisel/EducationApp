<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Universal Links: replace app.example.com with your real domain (the one
	     that serves /.well-known/apple-app-site-association). This file must be
	     linked to the Runner target in Xcode via the "Associated Domains"
	     capability (Signing & Capabilities) so CODE_SIGN_ENTITLEMENTS points here. -->
	<key>com.apple.developer.associated-domains</key>
	<array>
		<string>applinks:app.example.com</string>
	</array>
	<!-- Sign in with Apple. Also enable the "Sign in with Apple" capability on the
	     App ID in the Apple Developer portal and in Xcode (Signing & Capabilities)
	     so provisioning includes it. -->
	<key>com.apple.developer.applesignin</key>
	<array>
		<string>Default</string>
	</array>
</dict>
</plist>
